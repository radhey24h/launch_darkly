{
  /*
    LaunchDarklyConsolePOC – appsettings.json
    ==========================================
    Replace SdkKey with your real LaunchDarkly Server-Side SDK key.
    The key used by LaunchDarklyWorkerPOC is available in:
      LaunchDarklyWorkerPOC/src/MessageWorker/appsettings.json

    Feature flag key must already exist in your LaunchDarkly project and must
    return string variations "dotnet" and "python".
    The same flag key is used by LaunchDarklyWebPOC (backend-routing).
  */
  "LaunchDarkly": {
    "SdkKey": "sdk-YOUR-SDK-KEY-HERE",
    "FeatureFlagKey": "backend-routing",
    "DefaultVariation": "python",
    "StartWaitTimeSeconds": 10
  },
  "App": {
    /*
      Number of orders generated when no command-line argument is provided.
      Override at runtime without touching this file:
        dotnet run -- 10000
        dotnet run -- 100000
    */
    "DefaultOrderCount": 1000
  },
  "Logging": {
    "LogLevel": {
      /*
        Keep console output clean during demos.
        Only LaunchDarklyConsolePOC namespaces emit Information-level logs.
        LaunchDarkly SDK internal logs are suppressed to Warning.
      */
      "Default": "Warning",
      "LaunchDarklyConsolePOC": "Information",
      "LaunchDarkly": "Warning"
    }
  }
}
